    <string name="error_dialog_title">اوه نه! 🤦</string>
    <string name="error_dialog_tip_token_mismatch_retry">لطفاً برنامه را کاملاً ببندید و دوباره اجرا کنید. ممکن است اتصال با نکست‌کلاود دچار مشکل شده باشد.</string>
    <string name="error_dialog_tip_clear_storage_might_help">اگر مشکل همچنان باقی است، سعی کنید حافظه هر دو برنامه Nextcloud و Nextcloud Tables را پاک کنید.</string>
    <string name="error_dialog_tip_database_upgrade_failed">ارتقای پایگاه داده انجام نشد. لطفاً موضوع را گزارش کرده و فضای ذخیره‌سازی را پاک کنید.</string>
    <string name="error_dialog_tip_clear_storage">شما می‌توانید از طریق تنظیمات برنامه و بخش فضای ذخیره‌سازی، داده‌های آن را پاک کنید.</string>
    <string name="error_dialog_tip_offline_no_internet">به نظر می‌رسد سعی دارید بدون اتصال به اینترنت همگام‌سازی کنید.</string>
    <string name="error_dialog_tip_offline_connection_refused">اتصال رد شد؛ لطفاً دسترسی به سرور را از طریق مرورگر بررسی کنید.</string>
    <string name="error_dialog_tip_offline_connection_timeout">اتصال در زمان مقرر انجام نشد؛ لطفاً اینترنت خود را بررسی کنید.</string>
    <string name="error_dialog_tip_sync_only_on_wifi">اگر گزینه «همگام‌سازی فقط با وای‌فای» فعال باشد، تنها در صورت اتصال به وای‌فای همگام‌سازی انجام می‌شود.</string>
    <string name="error_dialog_tip_files_force_stop">مشکلی در برنامه Nextcloud شما به نظر می‌رسد. لطفاً برنامه Nextcloud و Tables را توقف اجباری کنید.</string>
    <string name="error_dialog_tip_files_delete_storage">اگر توقف اجباری کمکی نکرد، داده‌های هر دو برنامه را پاک کنید.</string>
    <string name="error_dialog_timeout_instance">پاسخی از سرور دریافت نشد. لطفاً از عملکرد صحیح سرور مطمئن شوید.</string>
    <string name="error_dialog_timeout_toggle">اتصال شبکه خود را بررسی کنید. روشن و خاموش کردن مجدد داده تلفن همراه یا وای‌فای می‌تواند کمک‌کننده باشد.</string>
    <string name="error_dialog_check_server">پاسخ سرور نادرست بود. لطفاً دسترسی به برنامه Tables را از طریق رابط وب بررسی کنید.</string>
    <string name="error_dialog_check_server_logs">مشکلی در نصب Nextcloud وجود دارد. لطفاً گزارش‌های (لاگ) سرور را بررسی کنید.</string>
    <string name="error_dialog_check_maintenance">لطفاً بررسی کنید که نکست‌کلاود در حالت تعمیر و نگهداری نباشد.</string>
    <string name="error_dialog_insufficient_storage">فضای ذخیره‌سازی نکست‌کلاود پر شده است. لطفاً برای همگام‌سازی، تعدادی از فایل‌ها را حذف کنید.</string>
    <string name="error_dialog_we_need_info">برای کمک به شما به اطلاعات فنی زیر نیاز داریم:</string>
    <string name="error_dialog_redirect">سرور پاسخ HTTP 302 داده است که احتمالاً به دلیل نصب نبودن برنامه Tables یا پیکربندی نادرست در فایل htaccess. است.</string>
    <string name="error_dialog_forbidden">شما دسترسی کافی ندارید. لطفاً جدول‌های به اشتراک گذاشته شده را بررسی کنید.</string>
    <string name="error_dialog_version_not_parsable">نسخه برنامه Tables روی سرور قابل تشخیص نیست. لطفاً از نصب و فعال بودن آن اطمینان حاصل کنید.</string>
    <string name="error_dialog_account_might_not_be_authorized">حساب شما ممکن است دیگر مجاز نباشد.</string>
    <string name="error_dialog_user_not_found_in_database">کاربر فعلی در پایگاه داده یافت نشد.</string>
    <string name="error_dialog_capabilities_not_parsable">ما نمی‌توانیم قابلیت‌های سرور را دریافت کنیم. لطفاً از سلامت عملکرد سرور مطمئن شوید.</string>
    <string name="error_dialog_attachment_upload_failed">بارگذاری پیوست انجام نشد. لطفاً روش دیگری را امتحان کنید.</string>
    <string name="error_dialog_certificate">مشکلی در گواهینامه سرور وجود دارد.</string>
    <string name="error_dialog_tip_disable_battery_optimizations">لطفاً تمامی بهینه‌سازی‌های باتری را برای برنامه‌های Nextcloud و Tables غیرفعال کنید.</string>
    <string name="error_dialog_unknown_error">به نظر می‌رسد سرور نکست‌کلاود در دسترس نیست. لطفاً اتصال اینترنت خود را بررسی کنید.</string>
    <string name="error_dialog_min_version">برنامه Tables به نسخه ۳.۱۸ یا بالاتر برنامه Nextcloud اندروید نیاز دارد.</string>
